#!/usr/bin/env bash
set -euo pipefail

repo="sohaha/zcodex"
per_page=100
confirm_delete=0
field_separator=$'\037'

usage() {
  cat >&2 <<'EOF'
[mise] 用法:
  mise run clear-actions
  mise run clear-actions --yes

说明:
  默认执行 dry-run，只列出将删除的 completed workflow runs。
  传入 --yes 后，才会真正删除 sohaha/zcodex 的 GitHub Actions 记录。
EOF
}

die() {
  echo "[mise] $*" >&2
  exit 1
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    die "缺少依赖: $1"
  fi
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --yes)
      confirm_delete=1
      ;;
    help|--help|-h)
      usage
      exit 0
      ;;
    *)
      usage
      die "未知参数: $1"
      ;;
  esac
  shift
done

require_command gh

if ! gh auth status >/dev/null 2>&1; then
  die "未检测到 gh 登录态，请先执行 gh auth login"
fi

runs_file="$(mktemp)"

cleanup() {
  rm -f "$runs_file"
}

trap cleanup EXIT

if ! gh api \
  --paginate \
  -H "Accept: application/vnd.github+json" \
  --jq '
    .workflow_runs[]
    | [
        (.id | tostring),
        ((.display_title // .name // "(unnamed)") | gsub("[[:space:]]+"; " ") | gsub("\u001f"; " ")),
        ((.status // "") | gsub("\u001f"; " ")),
        ((.conclusion // "") | gsub("\u001f"; " ")),
        ((.created_at // "") | gsub("\u001f"; " "))
      ]
    | join("\u001f")
  ' \
  "/repos/$repo/actions/runs?status=completed&per_page=$per_page" >"$runs_file"; then
  die "获取 workflow runs 失败"
fi

run_count="$(wc -l <"$runs_file" | tr -d '[:space:]')"

if [ "$run_count" = "0" ]; then
  echo "[mise] 未找到可处理的 completed workflow runs"
  exit 0
fi

echo "[mise] repo=$repo completed_runs=$run_count"

while IFS="$field_separator" read -r run_id title status conclusion created_at; do
  if [ "$confirm_delete" -eq 1 ]; then
    echo "[delete] run_id=$run_id title=$title status=$status conclusion=$conclusion created_at=$created_at"
    gh api \
      --method DELETE \
      -H "Accept: application/vnd.github+json" \
      "/repos/$repo/actions/runs/$run_id" >/dev/null
  else
    echo "[dry-run] run_id=$run_id title=$title status=$status conclusion=$conclusion created_at=$created_at"
  fi
done <"$runs_file"

if [ "$confirm_delete" -eq 1 ]; then
  echo "[mise] 已删除 $run_count 条 workflow run 记录"
else
  echo "[mise] dry-run 完成；如需真实删除，请追加 --yes"
fi
