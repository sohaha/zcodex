#!/usr/bin/env bash
#MISE description="构建 codex CLI，可选择本机构建或交叉编译目标"
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
jobs="${CARGO_BUILD_JOBS:-$(nproc)}"
export CARGO_PROFILE_DEV_DEBUG="${CARGO_PROFILE_DEV_DEBUG:-0}"
source "$script_dir/lib-artifact-size"
source "$script_dir/lib-speed-first-build"

target_requires_linux_build_deps() {
  local target="${CARGO_BUILD_TARGET:-}"
  local previous_was_target=0

  for arg in "$@"; do
    if [ "$previous_was_target" -eq 1 ]; then
      target="$arg"
      break
    fi

    case "$arg" in
      --target)
        previous_was_target=1
        ;;
      --target=*)
        target="${arg#--target=}"
        break
        ;;
    esac
  done

  if [ -z "$target" ]; then
    [ "$(uname -s)" = "Linux" ]
    return
  fi

  case "$target" in
    *linux*)
      return
      ;;
    *.json)
      local target_path="$target"
      if [ ! -f "$target_path" ] && [ -f "$codex_rs_dir/$target" ]; then
        target_path="$codex_rs_dir/$target"
      fi

      if [ -f "$target_path" ] && grep -Eq '"os"[[:space:]]*:[[:space:]]*"linux"' "$target_path"; then
        return
      fi
      ;;
  esac

  return 1
}

resolve_build_target() {
  local target="${CARGO_BUILD_TARGET:-}"
  local previous_was_target=0

  for arg in "$@"; do
    if [ "$previous_was_target" -eq 1 ]; then
      target="$arg"
      break
    fi

    case "$arg" in
      --target)
        previous_was_target=1
        ;;
      --target=*)
        target="${arg#--target=}"
        break
        ;;
    esac
  done

  printf '%s\n' "$target"
}

resolve_build_profile_dir() {
  local profile="debug"
  local previous_was_profile=0

  for arg in "$@"; do
    if [ "$previous_was_profile" -eq 1 ]; then
      profile="$arg"
      break
    fi

    case "$arg" in
      --release)
        profile="release"
        ;;
      --profile)
        previous_was_profile=1
        ;;
      --profile=*)
        profile="${arg#--profile=}"
        break
        ;;
    esac
  done

  if [ "$profile" = "dev" ]; then
    profile="debug"
  fi

  printf '%s\n' "$profile"
}

resolve_codex_bin() {
  local target_dir
  local build_target
  local profile_dir
  local slot

  if [ -n "${CARGO_TARGET_DIR:-}" ]; then
    target_dir="$CARGO_TARGET_DIR"
  else
    slot="$(bash "$codex_rs_dir/scripts/resolve-cargo-slot.sh" cargo build -p codex-cli --bin codex -j "$jobs" "$@")"
    target_dir="$(bash "$codex_rs_dir/scripts/resolve-cargo-target-dir.sh" "$slot")"
  fi
  build_target="$(resolve_build_target "$@")"
  profile_dir="$(resolve_build_profile_dir "$@")"

  if [ -n "$build_target" ]; then
    printf '%s\n' "$target_dir/$build_target/$profile_dir/codex"
    return
  fi

  printf '%s\n' "$target_dir/$profile_dir/codex"
}

can_use_built_codex_for_rtk_build() {
  local built_codex_bin="$1"

  [ -x "$built_codex_bin" ] || return 1
  "$built_codex_bin" rtk cargo build --help >/dev/null 2>&1
}

overwrite_installed_codex_if_present() {
  local built_codex_bin="$1"
  local installed_codex
  local built_codex_real
  local installed_codex_real
  local installed_dir
  local temp_installed_dir
  local temp_installed_codex

  installed_codex="$(command -v codex || true)"
  if [ -z "$installed_codex" ]; then
    return
  fi

  if [ ! -x "$built_codex_bin" ]; then
    echo "[build] 构建成功，但未找到产物：$built_codex_bin" >&2
    exit 1
  fi

  built_codex_real="$(realpath "$built_codex_bin")"
  installed_codex_real="$(realpath "$installed_codex")"
  if [ "$built_codex_real" = "$installed_codex_real" ]; then
    return
  fi

  installed_dir="$(dirname "$installed_codex_real")"
  if ! temp_installed_dir="$(mktemp -d "$installed_dir/.codex.tmp.XXXXXX")"; then
    echo "[build] 无法在 $installed_dir 创建临时目录，已跳过覆盖" >&2
    return
  fi
  temp_installed_codex="$temp_installed_dir/codex"

  if ! cp "$built_codex_bin" "$temp_installed_codex"; then
    rm -rf "$temp_installed_dir"
    echo "[build] 无法写入临时 codex 文件，已跳过覆盖" >&2
    return
  fi

  if ! mv -f "$temp_installed_codex" "$installed_codex_real"; then
    rm -rf "$temp_installed_dir"
    echo "[build] 无法原子替换 $installed_codex_real (可能正在运行)，已跳过覆盖" >&2
    return
  fi
  rmdir "$temp_installed_dir" 2>/dev/null || true
  echo "[build] 已使用 $built_codex_bin 原子覆盖 $installed_codex_real" >&2
}

ensure_linux_build_deps() {
  if ! target_requires_linux_build_deps "$@"; then
    return
  fi

  if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libcap; then
    return
  fi

  echo "[build] libcap 未就绪，先安装 Linux 构建依赖" >&2
  "$script_dir/deps"

  if ! command -v pkg-config >/dev/null 2>&1 || ! pkg-config --exists libcap; then
    echo "[build] libcap 仍不可用，请检查 pkg-config 和 libcap-dev 安装状态" >&2
    exit 1
  fi
}

run_build() {
  local built_codex_bin="$1"
  shift

  if can_use_built_codex_for_rtk_build "$built_codex_bin"; then
    set +e
    "$script_dir/rs-ext" "$built_codex_bin" rtk cargo build -p codex-cli --bin codex -j "$jobs" "$@"
    local status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      overwrite_installed_codex_if_present "$built_codex_bin"
      return 0
    fi
    echo "[build] 内置 RTK 构建快捷路径失败，回退到 cargo build" >&2
  fi

  "$script_dir/rs-ext" cargo build -p codex-cli --bin codex -j "$jobs" "$@"
  overwrite_installed_codex_if_present "$built_codex_bin"
}

main() {
  if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    cat >&2 <<'EOF'
[mise] 用法:
  mise run build [cargo build args...]
  mise run build cli [cargo build args...]
  mise run build codex [cargo build args...]
  mise run build local-release [cargo build args...]
  mise run build release [cargo build args...]
  mise run build ubuntu-linux-amd64 [args...]
  mise run build ubuntu-macos-arm64 [args...]
  mise run build ubuntu-win-amd64 [args...]
  mise run build ubuntu-win-arm64 [args...]

[mise] 默认会启用 speed-first 本地构建缓存：
  CODEX_BUILD_SPEED_FIRST=0              关闭 speed-first 默认值
  CODEX_BUILD_RAM_TARGET=0               强制本地 build 使用磁盘 target
  CODEX_BUILD_RAM_TARGET=1               强制本地 build 使用 /dev/shm target
  CODEX_BUILD_RAM_TARGET=auto            共享内存足够时自动切到 /dev/shm target
  CARGO_TARGET_DIR=/path/to/target       覆盖 target 目录
  SCCACHE_DIR=/path/to/sccache           覆盖 sccache 缓存目录
  SCCACHE_CACHE_SIZE=100G                覆盖 sccache 缓存上限
  TMPDIR=/path/to/tmp                    覆盖临时目录
EOF
    exit 0
  fi

  case "${1:-}" in
    cli|codex|codex-cli)
      shift
      ;;
    local-release|release)
      shift
      if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        cat >&2 <<'EOF'
[mise] 用法:
  mise run build local-release [cargo build args...]
  mise run build release [cargo build args...]

[mise] 该目标等价于：
  mise run build --release
EOF
        exit 0
      fi
      exec "$script_dir/build" --release "$@"
      ;;
    ubuntu-linux-amd64|ubuntu-macos-arm64|ubuntu-win-amd64|ubuntu-win-arm64)
      target_task="$1"
      shift
      exec "$script_dir/build-$target_task" "$@"
      ;;
  esac

  ensure_linux_build_deps "$@"
  configure_speed_first_build_defaults "$repo_root" "$repo_root/.cargo-target" "prefer-ram"
  print_speed_first_build_summary

  if [ -z "${RUSTC_WRAPPER:-}" ] && command -v sccache >/dev/null 2>&1; then
    export RUSTC_WRAPPER="$(command -v sccache)"
  fi

  if command -v mold >/dev/null 2>&1; then
    export RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }-C link-arg=-fuse-ld=mold"
  elif command -v ld.lld >/dev/null 2>&1; then
    export RUSTFLAGS="${RUSTFLAGS:+$RUSTFLAGS }-C link-arg=-fuse-ld=lld"
  fi

  local codex_bin
  codex_bin="$(resolve_codex_bin "$@")"
  run_build "$codex_bin" "$@"
  if [ "${CODEX_SKIP_ARTIFACT_SIZE_PRINT:-0}" != "1" ]; then
    print_artifact_size "build" "$codex_bin"
  fi
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
