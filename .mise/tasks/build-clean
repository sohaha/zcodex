#!/usr/bin/env bash
#MISE description="清理构建 codex CLI，忽略所有缓存确保最新产物"
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
CODEX_RS_DIR="$REPO_ROOT/codex-rs"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}[build-clean] 开始清理构建...${NC}"
echo -e "${YELLOW}[build-clean] 这将会删除所有缓存和构建产物${NC}"
echo ""

# Step 1: Clean codex-rs workspace
if [ -d "$CODEX_RS_DIR" ]; then
  echo -e "${YELLOW}[build-clean] 步骤 1/4: 清理 codex-rs 工作区...${NC}"
  cd "$CODEX_RS_DIR" && cargo clean
  cd "$REPO_ROOT"
  echo -e "${GREEN}[build-clean] ✓ codex-rs 工作区已清理${NC}"
else
  echo -e "${RED}[build-clean] ✗ 找不到 codex-rs 目录${NC}"
fi

echo ""

# Step 2: Clean active cargo target directory
ACTIVE_TARGET_DIR="$REPO_ROOT/.cargo-target"
if [ -d "$ACTIVE_TARGET_DIR" ]; then
  echo -e "${YELLOW}[build-clean] 步骤 2/4: 清理 target 目录 ($ACTIVE_TARGET_DIR)...${NC}"
  rm -rf "$ACTIVE_TARGET_DIR"
  echo -e "${GREEN}[build-clean] ✓ target 目录已清理${NC}"
else
  echo -e "${GREEN}[build-clean] ✓ target 目录不存在，跳过${NC}"
fi

echo ""

# Step 3: Clean sccache if available
if command -v sccache >/dev/null 2>&1; then
  echo -e "${YELLOW}[build-clean] 步骤 3/4: 清理 sccache 缓存...${NC}"
  # Try different sccache clear methods
  if sccache --help 2>&1 | grep -q "zero-stats"; then
    sccache --zero-stats >/dev/null 2>&1 || true
  elif sccache --help 2>&1 | grep -q "--clear"; then
    sccache --clear >/dev/null 2>&1 || true
  else
    # Fallback: remove cache directory
    rm -rf "${SCCACHE_DIR:-/workspace/.cache/sccache}" 2>/dev/null || true
  fi
  echo -e "${GREEN}[build-clean] ✓ sccache 缓存已清理${NC}"
else
  echo -e "${GREEN}[build-clean] ✓ sccache 未安装，跳过${NC}"
fi

echo ""

# Step 4: Run normal build
BUILD_ARGS=("$@")
if [ ${#BUILD_ARGS[@]} -eq 0 ]; then
  BUILD_ARGS=("--")
fi

echo -e "${YELLOW}[build-clean] 步骤 4/4: 执行全新构建...${NC}"
echo -e "${GREEN}[build-clean] 调用: mise run build ${BUILD_ARGS[*]}${NC}"
echo ""

# Execute the build
exec "$SCRIPT_DIR/build" "${BUILD_ARGS[@]}"
