#!/usr/bin/env bash
set -euo pipefail

os_name="$(uname -s)"

if [ "$os_name" = "Darwin" ]; then
  if ! command -v brew >/dev/null 2>&1; then
    echo "[mise] Homebrew 未安装，请先安装 Homebrew" >&2
    exit 1
  fi
  brew update
  brew install pkg-config openssl@3
elif command -v apt-get >/dev/null 2>&1; then
  sudo_cmd=()
  if [ "$EUID" -ne 0 ]; then
    sudo_cmd=(sudo)
  fi
  "${sudo_cmd[@]}" apt-get update
  "${sudo_cmd[@]}" apt-get install -y pkg-config libssl-dev libcap-dev
else
  echo "[mise] 未检测到受支持的包管理器，请手动安装 pkg-config、OpenSSL 和 libcap 开发包" >&2
  exit 1
fi
