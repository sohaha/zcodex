#!/usr/bin/env bash
set -euo pipefail

ensure_optional_sccache_wrapper() {
  if [ "${CODEX_DISABLE_SCCACHE:-0}" = "1" ]; then
    unset RUSTC_WRAPPER
    return
  fi

  local wrapper="${RUSTC_WRAPPER:-}"

  if [ -z "$wrapper" ]; then
    if command -v sccache >/dev/null 2>&1; then
      export RUSTC_WRAPPER
      RUSTC_WRAPPER="$(command -v sccache)"
    fi
    return
  fi

  case "${wrapper##*/}" in
    sccache)
      if [ "$wrapper" = "sccache" ]; then
        if command -v sccache >/dev/null 2>&1; then
          export RUSTC_WRAPPER
          RUSTC_WRAPPER="$(command -v sccache)"
        else
          echo "[build] RUSTC_WRAPPER=sccache but sccache is not on PATH; continuing without sccache" >&2
          unset RUSTC_WRAPPER
        fi
        return
      fi

      if [ ! -x "$wrapper" ]; then
        if command -v sccache >/dev/null 2>&1; then
          export RUSTC_WRAPPER
          RUSTC_WRAPPER="$(command -v sccache)"
        else
          echo "[build] RUSTC_WRAPPER=$wrapper but that sccache binary is missing; continuing without sccache" >&2
          unset RUSTC_WRAPPER
        fi
      fi
      ;;
  esac
}

probe_sccache_usable() {
  if [ "${CODEX_DISABLE_SCCACHE:-0}" = "1" ]; then
    unset RUSTC_WRAPPER
    return
  fi

  if [ "${CODEX_SCCACHE_PROBED:-0}" = "1" ]; then
    return
  fi
  export CODEX_SCCACHE_PROBED=1

  if ! command -v sccache >/dev/null 2>&1; then
    return
  fi
  if ! command -v rustc >/dev/null 2>&1; then
    return
  fi

  local output
  if ! output="$(env -u CARGO_INCREMENTAL sccache "$(command -v rustc)" -vV 2>&1)"; then
    if printf '%s' "$output" | grep -q "incremental compilation is prohibited"; then
      echo "[build] sccache rejects incremental compilation in this environment; disabling sccache" >&2
      export CODEX_DISABLE_SCCACHE=1
      unset RUSTC_WRAPPER
    fi
  fi
}

normalize_incremental_for_active_wrapper() {
  case "${RUSTC_WRAPPER:-}" in
    "" )
      return
      ;;
    */sccache|sccache)
      if [ -n "${CARGO_INCREMENTAL:-}" ]; then
        echo "[build] sccache 不支持设置 CARGO_INCREMENTAL; unsetting it before build" >&2
      fi
      unset CARGO_INCREMENTAL
      ;;
  esac
}

ram_build_root_is_usable() {
  local ram_root="${CODEX_BUILD_RAM_ROOT:-/dev/shm}"
  local min_free_kib="${CODEX_BUILD_RAM_TARGET_MIN_FREE_KIB:-12582912}"
  local free_kib

  [ -d "$ram_root" ] || return 1
  [ -w "$ram_root" ] || return 1

  free_kib="$(df -Pk "$ram_root" 2>/dev/null | awk 'NR==2 {print $4}')"
  [ -n "$free_kib" ] || return 1
  [ "$free_kib" -ge "$min_free_kib" ]
}

resolve_speed_first_tmpdir() {
  local repo_root="$1"
  local ram_root="${CODEX_BUILD_RAM_ROOT:-/dev/shm}"

  if [ -z "${TMPDIR:-}" ] && [ -d "$ram_root" ] && [ -w "$ram_root" ]; then
    printf '%s\n' "$ram_root/zcodex-mise-build/tmp"
    return
  fi

  printf '%s\n' "${TMPDIR:-$repo_root/.tmp/mise-build}"
}

resolve_speed_first_target_dir() {
  local repo_root="$1"
  local default_target_dir="$2"
  local target_mode="${3:-prefer-disk}"
  local ram_root="${CODEX_BUILD_RAM_ROOT:-/dev/shm}"
  local ram_target_policy="${CODEX_BUILD_RAM_TARGET:-auto}"

  if [ -n "${CARGO_TARGET_DIR:-}" ]; then
    printf '%s\n' "$CARGO_TARGET_DIR"
    return
  fi

  case "$ram_target_policy:$target_mode" in
    0:*|false:*|off:*|*:prefer-disk)
      printf '%s\n' "$default_target_dir"
      return
      ;;
    1:*|true:*|on:*)
      printf '%s\n' "$ram_root/zcodex-cargo-target"
      return
      ;;
    auto:prefer-ram)
      if ram_build_root_is_usable; then
        printf '%s\n' "$ram_root/zcodex-cargo-target"
        return
      fi
      ;;
  esac

  printf '%s\n' "$default_target_dir"
}

configure_speed_first_build_defaults() {
  local repo_root="$1"
  local default_target_dir="$2"
  local target_mode="${3:-prefer-disk}"

  if [ "${CODEX_BUILD_SPEED_FIRST:-1}" = "0" ]; then
    return
  fi

  export CARGO_TARGET_DIR="$(resolve_speed_first_target_dir "$repo_root" "$default_target_dir" "$target_mode")"
  export CARGO_INCREMENTAL="${CARGO_INCREMENTAL:-1}"
  export SCCACHE_DIR="${SCCACHE_DIR:-$repo_root/.cache/sccache}"
  export SCCACHE_CACHE_SIZE="${SCCACHE_CACHE_SIZE:-50G}"
  export TMPDIR="$(resolve_speed_first_tmpdir "$repo_root")"
  ensure_optional_sccache_wrapper
  probe_sccache_usable
  normalize_incremental_for_active_wrapper

  mkdir -p "$CARGO_TARGET_DIR" "$SCCACHE_DIR" "$TMPDIR"
}

print_speed_first_build_summary() {
  if [ "${CODEX_BUILD_SPEED_FIRST:-1}" = "0" ]; then
    return
  fi

  if [ "${CODEX_BUILD_SPEED_FIRST_SUMMARY_PRINTED:-0}" = "1" ]; then
    return
  fi
  export CODEX_BUILD_SPEED_FIRST_SUMMARY_PRINTED=1

  echo "[build] speed-first cache: target=$CARGO_TARGET_DIR sccache=$SCCACHE_DIR cache-size=$SCCACHE_CACHE_SIZE tmp=$TMPDIR" >&2
}
