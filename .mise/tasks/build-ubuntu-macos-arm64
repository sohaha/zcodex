#!/usr/bin/env bash
#MISE description="在 Ubuntu/Linux 上交叉构建 macOS arm64 二进制"
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
source "$script_dir/lib-artifact-size"
source "$script_dir/lib-ubuntu-macos-arm64"
target="aarch64-apple-darwin"
sdk_path="${SDKROOT:-${MACOS_SDK_PATH:-$repo_root/.cache/macos-sdk/MacOSX.sdk}}"

resolve_default_jobs() {
  local cpu_count max_jobs

  if command -v nproc >/dev/null 2>&1; then
    cpu_count="$(nproc)"
  else
    cpu_count="$(getconf _NPROCESSORS_ONLN 2>/dev/null || printf '1\n')"
  fi

  max_jobs="${CODEX_UBUNTU_MACOS_ARM64_MAX_JOBS:-8}"
  if [ "$cpu_count" -gt "$max_jobs" ]; then
    printf '%s\n' "$max_jobs"
  else
    printf '%s\n' "$cpu_count"
  fi
}

jobs="${CARGO_BUILD_JOBS:-$(resolve_default_jobs)}"

ensure_default_release_args() {
  for arg in "$@"; do
    case "$arg" in
      --release|--profile|--profile=*)
        printf '%s\0' "$@"
        return
        ;;
    esac
  done

  printf '%s\0' "$@" --release
}

resolve_build_profile_dir() {
  local profile="release"
  local previous_was_profile=0

  for arg in "$@"; do
    if [ "$previous_was_profile" -eq 1 ]; then
      profile="$arg"
      break
    fi

    case "$arg" in
      --release)
        profile="release"
        ;;
      --profile)
        previous_was_profile=1
        ;;
      --profile=*)
        profile="${arg#--profile=}"
        break
        ;;
    esac
  done

  if [ "$profile" = "dev" ]; then
    profile="debug"
  fi

  printf '%s\n' "$profile"
}

resolve_remote_ssh_target() {
  local ssh_schema="${CNB_VSCODE_REMOTE_SSH_SCHEMA:-}"
  local ssh_target

  if [ -z "$ssh_schema" ]; then
    return 1
  fi

  ssh_target="${ssh_schema#vscode://vscode-remote/ssh-remote+}"
  if [ "$ssh_target" = "$ssh_schema" ]; then
    return 1
  fi

  ssh_target="${ssh_target%%/*}"
  if ! printf '%s\n' "$ssh_target" | grep -Eq '.+@.+'; then
    return 1
  fi

  printf '%s\n' "$ssh_target"
}

has_clang() {
  command -v clang >/dev/null 2>&1
}

has_rust_target() {
  rustup target list --installed | grep -Fxq "$target"
}

bootstrap_cross_deps() {
  local should_bootstrap=0

  if [ "$sdk_path" = "$repo_root/.cache/macos-sdk/MacOSX.sdk" ] && [ ! -d "$sdk_path" ]; then
    should_bootstrap=1
  fi
  if ! has_clang || ! has_rust_target; then
    should_bootstrap=1
  fi

  if [ "$should_bootstrap" -eq 0 ] || [ "${CODEX_UBUNTU_MACOS_ARM64_DEPS_BOOTSTRAPPED:-0}" = "1" ]; then
    return
  fi

  echo "[build-ubuntu-macos-arm64] 检测到交叉编译依赖缺失，先同步运行 deps-ubuntu-macos-arm64..." >&2
  CODEX_UBUNTU_MACOS_ARM64_DEPS_BOOTSTRAPPED=1 "$script_dir/deps-ubuntu-macos-arm64"
}

ensure_cross_deps() {
  local zig_bin

  if [ "$(uname -s)" != "Linux" ]; then
    echo "[build-ubuntu-macos-arm64] 该 task 仅用于 Linux -> macOS arm64 交叉编译" >&2
    exit 1
  fi

  bootstrap_cross_deps

  if [ ! -d "$sdk_path" ]; then
    cat >&2 <<MSG
[build-ubuntu-macos-arm64] 缺少 macOS SDK: $sdk_path
[build-ubuntu-macos-arm64] 请先运行 `mise run deps-ubuntu-macos-arm64`；该任务会默认尝试下载公开 SDK，也支持 MACOS_SDK_URL / MACOS_SDK_TARBALL / MACOS_SDK_PATH。
MSG
    exit 1
  fi

  if ! command -v cargo >/dev/null 2>&1 || ! command -v rustup >/dev/null 2>&1; then
    echo "[build-ubuntu-macos-arm64] 缺少 Rust 工具链，请先安装 cargo/rustup" >&2
    exit 1
  fi

  if ! has_clang; then
    echo "[build-ubuntu-macos-arm64] 缺少 clang，请先运行 `mise run deps-ubuntu-macos-arm64`" >&2
    exit 1
  fi

  if ! has_rust_target; then
    echo "[build-ubuntu-macos-arm64] 缺少 Rust target $target，请先运行 `mise run deps-ubuntu-macos-arm64`" >&2
    exit 1
  fi

  zig_bin="$(ensure_zig_binary)"
  export CARGO_ZIGBUILD_ZIG_PATH
  CARGO_ZIGBUILD_ZIG_PATH="$zig_bin"
  export PATH
  PATH="$(dirname "$zig_bin"):$PATH"
  echo "[build-ubuntu-macos-arm64] 使用 Zig: $zig_bin" >&2
}

prepare_cross_wrappers() {
  local zig_cache_root wrapper_dir zig_cc_wrapper zig_cxx_wrapper zig_ar_wrapper zig_ranlib_wrapper
  local clang_link_wrapper runtime_marker runtime_dir runtime_source runtime_bin
  local latest_ubsan latest_compiler_rt

  zig_cache_root="${ZIG_GLOBAL_CACHE_DIR:-$HOME/.cache/zig}"
  wrapper_dir="$repo_root/.cache/ubuntu-macos-arm64-toolchain"
  zig_cc_wrapper="$wrapper_dir/zig-cc"
  zig_cxx_wrapper="$wrapper_dir/zig-cxx"
  zig_ar_wrapper="$wrapper_dir/zig-ar"
  zig_ranlib_wrapper="$wrapper_dir/zig-ranlib"
  clang_link_wrapper="$wrapper_dir/clang-link"
  mkdir -p "$wrapper_dir"

  cat > "$zig_cc_wrapper" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

zig_bin="${ZIG_BIN:?}"
sdk_path="${SDKROOT:?}"
out=(
  cc
  -isysroot "$sdk_path"
  -iframework "$sdk_path/System/Library/Frameworks"
  -isystem "$sdk_path/usr/include"
  -F"$sdk_path/System/Library/Frameworks"
  -L"$sdk_path/usr/lib"
)
needs_default_target=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    -Wp,-U*|-Wp,-D*)
      out+=( "${1#-Wp,}" )
      shift
      ;;
    --target=arm64-apple-macosx|--target=arm64-apple-darwin|--target=aarch64-apple-darwin)
      out+=( -target aarch64-macos-none )
      needs_default_target=0
      shift
      ;;
    --target)
      shift
      if [ "$#" -eq 0 ]; then
        echo "missing value for --target" >&2
        exit 1
      fi
      case "$1" in
        arm64-apple-macosx|arm64-apple-darwin|aarch64-apple-darwin)
          out+=( -target aarch64-macos-none )
          ;;
        *)
          out+=( --target="$1" )
          ;;
      esac
      needs_default_target=0
      shift
      ;;
    -target)
      out+=( "$1" )
      shift
      if [ "$#" -eq 0 ]; then
        echo "missing value for -target" >&2
        exit 1
      fi
      out+=( "$1" )
      needs_default_target=0
      shift
      ;;
    *)
      out+=( "$1" )
      shift
      ;;
  esac
done

if [ "$needs_default_target" -eq 1 ]; then
  out+=( -target aarch64-macos-none )
fi

exec "$zig_bin" "${out[@]}"
EOF

  cat > "$zig_cxx_wrapper" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

zig_bin="${ZIG_BIN:?}"
sdk_path="${SDKROOT:?}"
out=(
  c++
  -isysroot "$sdk_path"
  -iframework "$sdk_path/System/Library/Frameworks"
  -isystem "$sdk_path/usr/include"
  -F"$sdk_path/System/Library/Frameworks"
  -L"$sdk_path/usr/lib"
)
needs_default_target=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    -Wp,-U*|-Wp,-D*)
      out+=( "${1#-Wp,}" )
      shift
      ;;
    --target=arm64-apple-macosx|--target=arm64-apple-darwin|--target=aarch64-apple-darwin)
      out+=( -target aarch64-macos-none )
      needs_default_target=0
      shift
      ;;
    --target)
      shift
      if [ "$#" -eq 0 ]; then
        echo "missing value for --target" >&2
        exit 1
      fi
      case "$1" in
        arm64-apple-macosx|arm64-apple-darwin|aarch64-apple-darwin)
          out+=( -target aarch64-macos-none )
          ;;
        *)
          out+=( --target="$1" )
          ;;
      esac
      needs_default_target=0
      shift
      ;;
    -target)
      out+=( "$1" )
      shift
      if [ "$#" -eq 0 ]; then
        echo "missing value for -target" >&2
        exit 1
      fi
      out+=( "$1" )
      needs_default_target=0
      shift
      ;;
    *)
      out+=( "$1" )
      shift
      ;;
  esac
done

if [ "$needs_default_target" -eq 1 ]; then
  out+=( -target aarch64-macos-none )
fi

exec "$zig_bin" "${out[@]}"
EOF

  cat > "$zig_ar_wrapper" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
exec "${ZIG_BIN:?}" ar "$@"
EOF

  cat > "$zig_ranlib_wrapper" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
exec "${ZIG_BIN:?}" ranlib "$@"
EOF

  chmod +x \
    "$zig_cc_wrapper" \
    "$zig_cxx_wrapper" \
    "$zig_ar_wrapper" \
    "$zig_ranlib_wrapper"

  runtime_marker="$(mktemp)"
  runtime_dir="$(mktemp -d "${TMPDIR:-/tmp}/macos-runtime.XXXXXX")"
  runtime_source="$runtime_dir/runtime.c"
  runtime_bin="$runtime_dir/runtime"
  printf 'int main(void) { return 0; }\n' > "$runtime_source"
  "$zig_cc_wrapper" "$runtime_source" -o "$runtime_bin" >/dev/null 2>&1
  "$zig_cc_wrapper" -fsanitize=undefined "$runtime_source" -o "$runtime_bin" >/dev/null 2>&1
  latest_ubsan="$(
    find "$zig_cache_root/o" -type f -name 'libubsan_rt.a' -newer "$runtime_marker" -printf '%T@ %p\n' 2>/dev/null \
      | sort -nr \
      | head -n 1 \
      | cut -d' ' -f2-
  )"
  latest_compiler_rt="$(
    find "$zig_cache_root/o" -type f -name 'libcompiler_rt.a' -newer "$runtime_marker" -printf '%T@ %p\n' 2>/dev/null \
      | sort -nr \
      | head -n 1 \
      | cut -d' ' -f2-
  )"
  rm -f "$runtime_marker"
  rm -rf "$runtime_dir"

  if [ -z "$latest_ubsan" ]; then
    latest_ubsan="$(
      find "$zig_cache_root/o" -type f -name 'libubsan_rt.a' -printf '%T@ %p\n' 2>/dev/null \
        | sort -nr \
        | head -n 1 \
        | cut -d' ' -f2-
    )"
  fi
  if [ -z "$latest_compiler_rt" ]; then
    latest_compiler_rt="$(
      find "$zig_cache_root/o" -type f -name 'libcompiler_rt.a' -printf '%T@ %p\n' 2>/dev/null \
        | sort -nr \
        | head -n 1 \
        | cut -d' ' -f2-
    )"
  fi

  if [ -z "$latest_ubsan" ] || [ -z "$latest_compiler_rt" ]; then
    echo "[build-ubuntu-macos-arm64] 无法定位 Zig runtime archive，请清理 $zig_cache_root 后重试" >&2
    exit 1
  fi

  cat > "$clang_link_wrapper" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

sdk_path="${SDKROOT:?}"
out=(
  clang
  -fuse-ld=lld
  -isysroot "$sdk_path"
  -iframework "$sdk_path/System/Library/Frameworks"
  -F"$sdk_path/System/Library/Frameworks"
  -L"$sdk_path/usr/lib"
)
ubsan_rt="${CODEX_MACOS_UBSAN_RT:?}"
compiler_rt="${CODEX_MACOS_COMPILER_RT:?}"
needs_default_target=1

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target=*|-target)
      out+=( "$1" )
      shift
      if [ "${out[-1]}" = "-target" ] && [ "$#" -gt 0 ]; then
        out+=( "$1" )
        shift
      fi
      needs_default_target=0
      ;;
    *)
      out+=( "$1" )
      shift
      ;;
  esac
done

if [ "$needs_default_target" -eq 1 ]; then
  out+=( --target=arm64-apple-darwin )
fi

out+=( "$ubsan_rt" "$compiler_rt" )
exec "${out[@]}"
EOF

  chmod +x \
    "$clang_link_wrapper"

  export CODEX_MACOS_UBSAN_RT="$latest_ubsan"
  export CODEX_MACOS_COMPILER_RT="$latest_compiler_rt"
  export CC_aarch64_apple_darwin="$zig_cc_wrapper"
  export CXX_aarch64_apple_darwin="$zig_cxx_wrapper"
  export AR_aarch64_apple_darwin="$zig_ar_wrapper"
  export RANLIB_aarch64_apple_darwin="$zig_ranlib_wrapper"
  export CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$clang_link_wrapper"
  export CARGO_TARGET_AARCH64_APPLE_DARWIN_AR="$zig_ar_wrapper"
}

ensure_data_const_read_only_flag() {
  local binary="$1"

  perl - "$binary" <<'EOF'
use strict;
use warnings;
use Fcntl qw(SEEK_SET);

my $path = shift @ARGV;
open my $fh, '+<:raw', $path or die "open $path: $!";
read($fh, my $header, 32) == 32 or die "read mach header: $!";

my ($magic, undef, undef, undef, $ncmds, undef, undef, undef) = unpack('V8', $header);
die "unsupported Mach-O header in $path\n" if $magic != 0xfeedfacf;

my $offset = 32;
my $patched = 0;

for (1 .. $ncmds) {
  seek($fh, $offset, SEEK_SET) or die "seek load command: $!";
  read($fh, my $load_cmd, 8) == 8 or die "read load command: $!";
  my ($cmd, $cmdsize) = unpack('V2', $load_cmd);

  if ($cmd == 0x19) {
    seek($fh, $offset + 8, SEEK_SET) or die "seek segment name: $!";
    read($fh, my $segname, 16) == 16 or die "read segment name: $!";
    $segname =~ s/\0.*//s;

    if ($segname eq '__DATA_CONST') {
      seek($fh, $offset + 68, SEEK_SET) or die "seek segment flags: $!";
      read($fh, my $raw_flags, 4) == 4 or die "read segment flags: $!";
      my $flags = unpack('V', $raw_flags);
      my $new_flags = $flags | 0x10;
      if ($new_flags != $flags) {
        seek($fh, $offset + 68, SEEK_SET) or die "rewrite segment flags: $!";
        print {$fh} pack('V', $new_flags) or die "write segment flags: $!";
      }
      $patched = 1;
      last;
    }
  }

  $offset += $cmdsize;
}

die "missing __DATA_CONST segment in $path\n" if !$patched;
EOF
}

ensure_cross_deps "$@"

if [ -z "${RUSTC_WRAPPER:-}" ] && command -v sccache >/dev/null 2>&1; then
  export RUSTC_WRAPPER="$(command -v sccache)"
fi

if [ -z "${LIBCLANG_PATH:-}" ] && command -v ldconfig >/dev/null 2>&1; then
  libclang_path="$(ldconfig -p | grep -m1 'libclang\.so' | sed -E 's/.*=> (.*)$/\1/' || true)"
  if [ -n "$libclang_path" ]; then
    export LIBCLANG_PATH
    LIBCLANG_PATH="$(dirname "$libclang_path")"
  fi
fi

export SDKROOT="$sdk_path"
export MACOSX_DEPLOYMENT_TARGET="${MACOSX_DEPLOYMENT_TARGET:-11.0}"
export CARGO_PROFILE_DEV_DEBUG="${CARGO_PROFILE_DEV_DEBUG:-0}"
shared_target_dir="$repo_root/.cargo-target"
if [ -z "${CARGO_TARGET_DIR:-}" ] || [ "$CARGO_TARGET_DIR" = "$shared_target_dir" ]; then
  export CARGO_TARGET_DIR="$repo_root/.cargo-target-cross-macos-arm64"
fi
mkdir -p "$CARGO_TARGET_DIR"
# On Linux host, libz-sys may pick host pkg-config paths like x86_64-linux-gnu.
# Force vendored/probed build path for Apple target to avoid invalid linker search dirs.
export ZLIB_NO_PKG_CONFIG="${ZLIB_NO_PKG_CONFIG:-1}"
sdk_cflags="-isysroot $sdk_path -iframework $sdk_path/System/Library/Frameworks -isystem $sdk_path/usr/include"
export CFLAGS_aarch64_apple_darwin="${CFLAGS_aarch64_apple_darwin:-$sdk_cflags}"
export CXXFLAGS_aarch64_apple_darwin="${CXXFLAGS_aarch64_apple_darwin:-$sdk_cflags}"
export CPPFLAGS_aarch64_apple_darwin="${CPPFLAGS_aarch64_apple_darwin:-$sdk_cflags}"
export BINDGEN_EXTRA_CLANG_ARGS="${BINDGEN_EXTRA_CLANG_ARGS:-$sdk_cflags}"
export COREAUDIO_SDK_PATH="${COREAUDIO_SDK_PATH:-$sdk_path}"
export ZIG_BIN="$CARGO_ZIGBUILD_ZIG_PATH"

prepare_cross_wrappers

profile_dir="$(resolve_build_profile_dir "$@")"
mapfile -d '' -t build_args < <(ensure_default_release_args "$@")
output_bin="${CARGO_TARGET_DIR:-$codex_rs_dir/target}/$target/$profile_dir/codex"

"$script_dir/rs-ext" cargo build -p codex-cli --bin codex -j "$jobs" --target "$target" "${build_args[@]}"
ensure_data_const_read_only_flag "$output_bin"

dist_bin="$(move_artifact_to_dist "$output_bin" "$target" "$repo_root")"
print_artifact_size "build-ubuntu-macos-arm64" "$dist_bin"

if remote_ssh_target="$(resolve_remote_ssh_target)"; then
  printf '\n下载命令:\nscp %s:%s ~/.local/bin/codex &&  codesign --force --sign - ~/.local/bin/codex\n' \
    "$remote_ssh_target" \
    "$dist_bin"
else
  echo "[build-ubuntu-macos-arm64] 未检测到可用的 CNB_VSCODE_REMOTE_SSH_SCHEMA，已跳过下载命令输出" >&2
fi
