#!/usr/bin/env bash
#MISE description="后台保持 cnb.space SSH 连接，断开自动重连"
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
state_dir="$repo_root/.tmp/cnb-space-ssh-keepalive"
pid_file="$state_dir/daemon.pid"
log_file="$state_dir/daemon.log"
target_file="$state_dir/target"

ssh_bin="${CNB_SSH_BIN:-ssh}"
reconnect_delay_seconds="${CNB_SSH_RECONNECT_DELAY_SECONDS:-5}"
connect_timeout_seconds="${CNB_SSH_CONNECT_TIMEOUT_SECONDS:-10}"
server_alive_interval="${CNB_SSH_SERVER_ALIVE_INTERVAL:-30}"
server_alive_count_max="${CNB_SSH_SERVER_ALIVE_COUNT_MAX:-3}"
strict_host_key_checking="${CNB_SSH_STRICT_HOST_KEY_CHECKING:-accept-new}"

timestamp() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

validate_positive_integer() {
  local name="$1"
  local value="$2"

  case "$value" in
    ''|*[!0-9]*)
      echo "[cnb-space-ssh-keepalive] $name 必须是正整数，当前值: $value" >&2
      exit 1
      ;;
  esac

  if [ "$value" -le 0 ]; then
    echo "[cnb-space-ssh-keepalive] $name 必须大于 0，当前值: $value" >&2
    exit 1
  fi
}

ensure_state_dir() {
  mkdir -p "$state_dir"
}

resolve_remote_ssh_target() {
  local ssh_schema="${CNB_VSCODE_REMOTE_SSH_SCHEMA:-}"
  local ssh_target

  if [ -z "$ssh_schema" ]; then
    echo "[cnb-space-ssh-keepalive] 缺少环境变量 CNB_VSCODE_REMOTE_SSH_SCHEMA" >&2
    exit 1
  fi

  ssh_target="${ssh_schema#vscode://vscode-remote/ssh-remote+}"
  if [ "$ssh_target" = "$ssh_schema" ]; then
    echo "[cnb-space-ssh-keepalive] CNB_VSCODE_REMOTE_SSH_SCHEMA 格式不正确: $ssh_schema" >&2
    exit 1
  fi

  ssh_target="${ssh_target%%/*}"
  if ! printf '%s\n' "$ssh_target" | grep -Eq '.+@.+'; then
    echo "[cnb-space-ssh-keepalive] 无法从 CNB_VSCODE_REMOTE_SSH_SCHEMA 解析 SSH 目标: $ssh_schema" >&2
    exit 1
  fi

  printf '%s\n' "$ssh_target"
}

read_pid() {
  if [ ! -f "$pid_file" ]; then
    return 1
  fi

  cat "$pid_file"
}

list_daemon_pids() {
  pgrep -f "bash $script_path --daemon" || true
}

is_process_running() {
  local pid="$1"

  [ -n "$pid" ] && kill -0 "$pid" >/dev/null 2>&1
}

cleanup_state_if_current() {
  local recorded_pid

  if [ ! -f "$pid_file" ]; then
    return
  fi

  recorded_pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [ "$recorded_pid" = "$$" ]; then
    rm -f "$pid_file"
    rm -f "$target_file"
  fi
}

handle_shutdown() {
  cleanup_state_if_current
  exit 0
}

ensure_runtime_requirements() {
  validate_positive_integer "CNB_SSH_RECONNECT_DELAY_SECONDS" "$reconnect_delay_seconds"
  validate_positive_integer "CNB_SSH_CONNECT_TIMEOUT_SECONDS" "$connect_timeout_seconds"
  validate_positive_integer "CNB_SSH_SERVER_ALIVE_INTERVAL" "$server_alive_interval"
  validate_positive_integer "CNB_SSH_SERVER_ALIVE_COUNT_MAX" "$server_alive_count_max"

  if ! command -v "$ssh_bin" >/dev/null 2>&1; then
    echo "[cnb-space-ssh-keepalive] 找不到 SSH 可执行文件: $ssh_bin" >&2
    exit 1
  fi
}

run_daemon() {
  local target

  trap cleanup_state_if_current EXIT
  trap handle_shutdown INT TERM

  ensure_state_dir
  ensure_runtime_requirements
  target="$(resolve_remote_ssh_target)"
  printf '%s\n' "$$" >"$pid_file"
  printf '%s\n' "$target" >"$target_file"

  while true; do
    printf '[%s] connecting to %s\n' "$(timestamp)" "$target"
    if "$ssh_bin" \
      -N \
      -T \
      -o "BatchMode=yes" \
      -o "ConnectTimeout=$connect_timeout_seconds" \
      -o "StrictHostKeyChecking=$strict_host_key_checking" \
      -o "ServerAliveInterval=$server_alive_interval" \
      -o "ServerAliveCountMax=$server_alive_count_max" \
      "$target"; then
      exit_code=0
    else
      exit_code=$?
    fi

    printf '[%s] ssh exited with code %s, retrying in %s seconds\n' \
      "$(timestamp)" \
      "$exit_code" \
      "$reconnect_delay_seconds"
    sleep "$reconnect_delay_seconds"
  done
}

start_daemon() {
  local -a existing_pids=()
  local daemon_pid

  ensure_state_dir
  ensure_runtime_requirements
  resolve_remote_ssh_target >/dev/null

  mapfile -t existing_pids < <(list_daemon_pids)
  if [ "${#existing_pids[@]}" -gt 0 ]; then
    printf '%s\n' "${existing_pids[0]}" >"$pid_file"
    printf '已在后台运行，pid=%s\n日志: %s\n' "${existing_pids[0]}" "$log_file"
    return
  fi

  rm -f "$pid_file"
  : >"$log_file"

  nohup "$script_path" --daemon >>"$log_file" 2>&1 </dev/null &
  daemon_pid=$!

  sleep 1
  if ! is_process_running "$daemon_pid"; then
    echo "[cnb-space-ssh-keepalive] 后台任务启动失败，请检查日志: $log_file" >&2
    exit 1
  fi

  printf '%s\n' "$daemon_pid" >"$pid_file"
  printf '已启动后台 SSH 保活任务，pid=%s\n日志: %s\n' "$daemon_pid" "$log_file"
}

status_daemon() {
  local -a existing_pids=()
  local target="<unknown>"

  mapfile -t existing_pids < <(list_daemon_pids)
  if [ -f "$target_file" ]; then
    target="$(cat "$target_file")"
  fi

  if [ "${#existing_pids[@]}" -gt 0 ]; then
    printf '%s\n' "${existing_pids[0]}" >"$pid_file"
    printf '运行中，pid=%s\n日志: %s\n目标: %s\n' "${existing_pids[0]}" "$log_file" "$target"
    return
  fi

  echo "未运行"
  exit 1
}

stop_daemon() {
  local -a existing_pids=()
  local -a child_pids=()
  local pid
  local child_pid

  mapfile -t existing_pids < <(list_daemon_pids)
  if [ "${#existing_pids[@]}" -eq 0 ]; then
    rm -f "$pid_file"
    rm -f "$target_file"
    echo "未运行"
    return
  fi

  for pid in "${existing_pids[@]}"; do
    mapfile -t child_pids < <(pgrep -P "$pid" || true)
    for child_pid in "${child_pids[@]}"; do
      kill "$child_pid" >/dev/null 2>&1 || true
    done
    kill "$pid"
  done

  sleep 1
  for pid in "${existing_pids[@]}"; do
    if is_process_running "$pid"; then
      mapfile -t child_pids < <(pgrep -P "$pid" || true)
      for child_pid in "${child_pids[@]}"; do
        kill -9 "$child_pid" >/dev/null 2>&1 || true
      done
      kill -9 "$pid" >/dev/null 2>&1 || true
    fi
  done

  rm -f "$pid_file"
  rm -f "$target_file"
  printf '已停止，共 %s 个实例\n' "${#existing_pids[@]}"
}

action="${1:-start}"

case "$action" in
  start)
    start_daemon
    ;;
  status)
    status_daemon
    ;;
  stop)
    stop_daemon
    ;;
  --daemon)
    run_daemon
    ;;
  *)
    echo "用法: mise run cnb-space-ssh-keepalive [start|status|stop]" >&2
    exit 1
    ;;
esac
