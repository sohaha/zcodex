#!/usr/bin/env bash
#MISE description="在 Ubuntu/Linux 上交叉构建 Windows arm64 二进制"
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
source "$script_dir/lib-artifact-size"
source "$script_dir/lib-cargo-workspace-version"
source "$script_dir/lib-speed-first-build"
target="aarch64-pc-windows-gnullvm"
target_label="Windows arm64"
build_task_name="build-ubuntu-win-arm64"
deps_task_name="deps-ubuntu-win-arm64"
cross_build_description="Linux -> Windows arm64"
bootstrap_guard_var="CODEX_UBUNTU_WIN_ARM64_DEPS_BOOTSTRAPPED"
source "$script_dir/lib-ubuntu-win"
jobs="${CARGO_BUILD_JOBS:-$(nproc)}"

configure_speed_first_build_defaults "$repo_root" "$repo_root/.cargo-target" "prefer-disk"
print_speed_first_build_summary
ensure_cross_deps
codex_version="$(resolve_codex_release_version "$@")"
mapfile -d '' -t task_args < <(strip_codex_release_version_args "$@")
export_codex_release_version_if_present "$codex_version" "build-ubuntu-win-arm64"
activate_cargo_workspace_version_override "$codex_rs_dir" "$codex_version" "build-ubuntu-win-arm64"
mapfile -d '' -t build_args < <(ensure_default_release_args "${task_args[@]}")
profile_dir="$(resolve_build_profile_dir "${build_args[@]}")"
target_dir="$(
  resolve_rs_ext_target_dir \
    cargo zigbuild -p codex-cli --bin codex -j "$jobs" --target "$target" "${build_args[@]}"
)"
output_bin="$target_dir/$target/$profile_dir/codex.exe"
prime_windows_gnullvm_rusty_v8_artifacts "$profile_dir"

"$script_dir/rs-ext" cargo zigbuild -p codex-cli --bin codex -j "$jobs" --target "$target" "${build_args[@]}"

dist_bin="$(move_artifact_to_dist "$output_bin" "$target" "$repo_root")"
print_artifact_size "build-ubuntu-win-arm64" "$dist_bin"
