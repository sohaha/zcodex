#!/usr/bin/env bash
#MISE description="在外部磁盘或自定义目录运行 Rust 命令"
set -euo pipefail

if [ "$#" -eq 0 ]; then
  set -- cargo build
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
slot="$(bash "$codex_rs_dir/scripts/resolve-cargo-slot.sh" "$@")"
external_volume="${EXTERNAL_VOLUME:-/Volumes/V2}"
external_tmp_root="${EXTERNAL_TMP_ROOT:-$external_volume/tmp}"
external_target_dir="${EXTERNAL_TARGET_DIR:-$external_tmp_root/zcodex-cargo-target}"
use_external_build_root=0

if [ -n "${EXTERNAL_VOLUME:-}" ] || [ -n "${EXTERNAL_TMP_ROOT:-}" ] || [ -n "${EXTERNAL_TARGET_DIR:-}" ]; then
  use_external_build_root=1
fi

if [ "$use_external_build_root" -eq 0 ]; then
  :
elif [ ! -d "$external_volume" ]; then
  echo "[mise] external build root does not exist: $external_volume" >&2
elif [ -w "$external_volume" ]; then
  mkdir -p "$external_tmp_root" "$external_target_dir"
  if [ -w "$external_tmp_root" ] && [ -w "$external_target_dir" ]; then
    export TMPDIR="$external_tmp_root"
    export CARGO_TARGET_DIR="$external_target_dir"
    echo "[mise] using external build root: $external_tmp_root" >&2
  else
    echo "[mise] external build root is not writable: $external_tmp_root" >&2
  fi
else
  echo "[mise] external build root is not writable: $external_volume" >&2
fi

if [ "${CODEX_CARGO_HOME_DISABLE:-0}" != "1" ]; then
  export CARGO_HOME="$(bash "$codex_rs_dir/scripts/resolve-cargo-home-dir.sh" "$slot")"
  mkdir -p "$CARGO_HOME"
fi

if [ "${CODEX_CARGO_TARGET_DISABLE:-0}" != "1" ]; then
  export CARGO_TARGET_DIR="$(bash "$codex_rs_dir/scripts/resolve-cargo-target-dir.sh" "$slot")"
  mkdir -p "$CARGO_TARGET_DIR"
fi

# sccache rejects any explicit CARGO_INCREMENTAL setting in this environment;
# keep the rust entrypoint deterministic so wrappers and direct cargo runs
# behave the same.
unset CARGO_INCREMENTAL

cd "$codex_rs_dir"
exec "$@"
