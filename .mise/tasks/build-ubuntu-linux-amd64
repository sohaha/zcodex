#!/usr/bin/env bash
#MISE description="在 Ubuntu/Linux 上构建 Linux amd64 发行二进制"
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
source "$script_dir/lib-artifact-size"
source "$script_dir/lib-speed-first-build"
target="x86_64-unknown-linux-gnu"
jobs="${CARGO_BUILD_JOBS:-$(nproc)}"

ensure_default_release_args() {
  for arg in "$@"; do
    case "$arg" in
      --release|--profile|--profile=*)
        printf '%s\0' "$@"
        return
        ;;
    esac
  done

  printf '%s\0' "$@" --release
}

resolve_remote_ssh_target() {
  local ssh_schema="${CNB_VSCODE_REMOTE_SSH_SCHEMA:-}"
  local ssh_target

  if [ -z "$ssh_schema" ]; then
    return 1
  fi

  ssh_target="${ssh_schema#vscode://vscode-remote/ssh-remote+}"
  if [ "$ssh_target" = "$ssh_schema" ]; then
    return 1
  fi

  ssh_target="${ssh_target%%/*}"
  if ! printf '%s\n' "$ssh_target" | grep -Eq '.+@.+'; then
    return 1
  fi

  printf '%s\n' "$ssh_target"
}

resolve_rs_ext_target_dir() {
  local slot

  if [ "${CODEX_CARGO_TARGET_DISABLE:-0}" = "1" ] && [ -n "${CARGO_TARGET_DIR:-}" ]; then
    printf '%s\n' "$CARGO_TARGET_DIR"
    return
  fi

  slot="$(
    bash "$codex_rs_dir/scripts/resolve-cargo-slot.sh" \
      cargo build -p codex-cli --bin codex -j "$jobs" --target "$target" "$@"
  )"
  bash "$codex_rs_dir/scripts/resolve-cargo-target-dir.sh" "$slot"
}

if [ "$(uname -s)" != "Linux" ]; then
  echo "[build-ubuntu-linux-amd64] 该 task 仅用于 Ubuntu/Linux 构建 Linux amd64" >&2
  exit 1
fi

configure_speed_first_build_defaults "$repo_root" "$repo_root/.cargo-target" "prefer-disk"
print_speed_first_build_summary
mapfile -d '' -t build_args < <(ensure_default_release_args "$@")
profile_dir="release"
for arg in "${build_args[@]}"; do
  case "$arg" in
    --profile)
      next_is_profile=1
      ;;
    --profile=*)
      profile_dir="${arg#--profile=}"
      next_is_profile=0
      ;;
    --release)
      profile_dir="release"
      next_is_profile=0
      ;;
    *)
      if [ "${next_is_profile:-0}" -eq 1 ]; then
        profile_dir="$arg"
        next_is_profile=0
      fi
      ;;
  esac
done

if [ "$profile_dir" = "dev" ]; then
  profile_dir="debug"
fi

target_dir="$(resolve_rs_ext_target_dir "${build_args[@]}")"
output_bin="$target_dir/$target/$profile_dir/codex"
CODEX_SKIP_ARTIFACT_SIZE_PRINT=1 "$script_dir/build" --target "$target" "${build_args[@]}"
dist_bin="$(move_artifact_to_dist "$output_bin" "$target" "$repo_root")"
print_artifact_size "build-ubuntu-linux-amd64" "$dist_bin"

if remote_ssh_target="$(resolve_remote_ssh_target)"; then
  printf '\n下载命令:\nscp %s:%s ./codex\n' \
    "$remote_ssh_target" \
    "$dist_bin"
else
  echo "[build-ubuntu-linux-amd64] 未检测到可用的 CNB_VSCODE_REMOTE_SSH_SCHEMA，已跳过下载命令输出" >&2
fi
