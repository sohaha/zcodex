#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
target="x86_64-unknown-linux-gnu"

ensure_default_release_args() {
  for arg in "$@"; do
    case "$arg" in
      --release|--profile|--profile=*)
        printf '%s\0' "$@"
        return
        ;;
    esac
  done

  printf '%s\0' "$@" --release
}

resolve_build_profile_dir() {
  local profile="release"
  local previous_was_profile=0

  for arg in "$@"; do
    if [ "$previous_was_profile" -eq 1 ]; then
      profile="$arg"
      break
    fi

    case "$arg" in
      --release)
        profile="release"
        ;;
      --profile)
        previous_was_profile=1
        ;;
      --profile=*)
        profile="${arg#--profile=}"
        break
        ;;
    esac
  done

  if [ "$profile" = "dev" ]; then
    profile="debug"
  fi

  printf '%s\n' "$profile"
}

if [ "$(uname -s)" != "Linux" ]; then
  echo "[build-ubuntu-linux-amd64] 该 task 仅用于 Ubuntu/Linux 构建 Linux amd64" >&2
  exit 1
fi

mapfile -d '' -t build_args < <(ensure_default_release_args "$@")
profile_dir="$(resolve_build_profile_dir "${build_args[@]}")"
output_bin="${CARGO_TARGET_DIR:-$codex_rs_dir/target}/$target/$profile_dir/codex"

"$script_dir/build" --target "$target" "${build_args[@]}"

echo "[build-ubuntu-linux-amd64] 构建完成: $output_bin" >&2
