#!/usr/bin/env bash
#MISE description="在 Ubuntu/Linux 上交叉构建 Windows amd64 二进制"
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
codex_rs_dir="$repo_root/codex-rs"
source "$script_dir/lib-artifact-size"
source "$script_dir/lib-speed-first-build"
target="x86_64-pc-windows-msvc"
target_label="Windows amd64"
build_task_name="build-ubuntu-win-amd64"
deps_task_name="deps-ubuntu-win-amd64"
cross_build_description="Linux -> Windows amd64"
bootstrap_guard_var="CODEX_UBUNTU_WIN_AMD64_DEPS_BOOTSTRAPPED"
source "$script_dir/lib-ubuntu-win"
jobs="${CARGO_BUILD_JOBS:-$(nproc)}"

configure_speed_first_build_defaults "$repo_root" "$repo_root/.cargo-target" "prefer-disk"
print_speed_first_build_summary
ensure_cross_deps
mapfile -d '' -t build_args < <(ensure_default_release_args "$@")
profile_dir="$(resolve_build_profile_dir "${build_args[@]}")"
target_dir="$(
  resolve_rs_ext_target_dir \
    cargo xwin build -p codex-cli --bin codex -j "$jobs" --target "$target" "${build_args[@]}"
)"
output_bin="$target_dir/$target/$profile_dir/codex.exe"
"$script_dir/rs-ext" cargo xwin build -p codex-cli --bin codex -j "$jobs" --target "$target" "${build_args[@]}"

dist_bin="$(move_artifact_to_dist "$output_bin" "$target" "$repo_root")"
print_artifact_size "build-ubuntu-win-amd64" "$dist_bin"
print_remote_download_command "$dist_bin"
